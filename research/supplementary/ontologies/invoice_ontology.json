    {"id": "document_language", "type": "dimension", "label": "Document Language", "examples": ["English only", "Serbian/English bilingual"]},
    {"id": "rebate", "type": "property", "label": "Rebate / Discount", "examples": ["0.00", "0%"]},
    {"id": "issuer_signature_block", "type": "class", "label": "Signature and Responsibility Block", "examples": ["Responsible person details, signature line, stamp"]},
    {"id": "constraint_total_calculation", "type": "constraint", "label": "Total Amount Calculation Rule", "description": "Total must equal sum of all line item amounts; for time-based: hourly_rate × hours_per_day × working_days"},
    {"id": "constraint_vat_export", "type": "constraint", "label": "VAT Export Exemption Rule", "description": "Cross-border service exports are VAT-exempt; VAT amount must be 0 with legal citation"},
    {"id": "constraint_rsd_conversion", "type": "constraint", "label": "RSD Conversion Requirement", "description": "Serbian formal invoices must show total converted to RSD at NBS rate on invoice date"}
