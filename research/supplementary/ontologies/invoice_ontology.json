{
  "id": "00000000-0000-0000-0000-000000000000",
  "name": "Software Services Invoice Ontology",
  "description": "A US-domestic B2B invoice document type used by software staffing and development companies to bill clients for engineering services, typically on a monthly billing cycle with time-and-materials or fixed-fee pricing.",
  "domain": "finance",
  "_anonymization_note": "Schema-only release. The structural ontology (47 nodes, edges, types, semantics) is unchanged from the version actually used in the §5.5 generative validation experiment; all `examples` arrays have been replaced with synthetic US-domestic placeholders (Delaware LLC seller, US bank routing/account numbers, EIN tax IDs, USD-only amounts) so that no real customer, contractor, or banking data is exposed.",
  "nodes": [
    {"id": "invoice", "type": "class", "label": "Invoice", "examples": ["Invoice INV-001"]},
    {"id": "invoice_number", "type": "property", "label": "Invoice Number", "examples": ["INV-001"]},
    {"id": "invoice_date", "type": "property", "label": "Invoice Issue Date", "examples": ["MM/DD/YYYY"]},
    {"id": "delivery_date", "type": "property", "label": "Delivery Date", "examples": ["MM/DD/YYYY"]},
    {"id": "billing_period", "type": "property", "label": "Billing Period", "examples": ["Month 16 - Next Month 15"]},
    {"id": "contract_number", "type": "property", "label": "Contract Number / SOW Reference", "examples": ["SOW-XXXXXXXXX"]},
    {"id": "seller", "type": "class", "label": "Seller / Issuer", "examples": ["Example Software Services LLC"]},
    {"id": "seller_name", "type": "property", "label": "Seller Name", "examples": ["EXAMPLE SOFTWARE SERVICES LLC"]},
    {"id": "seller_address", "type": "property", "label": "Seller Address", "examples": ["100 Market St, Suite 500, San Francisco, CA 94105"]},
    {"id": "seller_tax_id", "type": "property", "label": "Seller Tax Identification Number", "examples": ["EIN: XX-XXXXXXX"]},
    {"id": "seller_registry_id", "type": "property", "label": "Seller Business Registration Number", "examples": ["Business Registration No.: XXXXXXXX"]},
    {"id": "seller_contact", "type": "property", "label": "Seller Contact Information", "examples": ["+1-415-XXX-XXXX, invoicing@example.com"]},
    {"id": "buyer", "type": "class", "label": "Buyer / Client", "examples": ["Acme Corp Inc."]},
    {"id": "buyer_name", "type": "property", "label": "Buyer Name", "examples": ["Acme Corp Inc."]},
    {"id": "buyer_address", "type": "property", "label": "Buyer Address", "examples": ["100 Example Avenue, Demo City, CA 94000, USA"]},
    {"id": "buyer_tax_id", "type": "property", "label": "Buyer Tax Identification Number", "examples": ["EIN: XX-XXXXXXX"]},
    {"id": "seller_bank", "type": "class", "label": "Seller Bank Account", "examples": ["Example Bank, San Francisco, CA"]},
    {"id": "bank_name", "type": "property", "label": "Bank Name", "examples": ["Example Bank, San Francisco, CA"]},
    {"id": "iban", "type": "property", "label": "IBAN", "examples": ["n/a (US domestic)"]},
    {"id": "swift_bic", "type": "property", "label": "SWIFT / BIC Code", "examples": ["n/a (US domestic)"]},
    {"id": "routing_number", "type": "property", "label": "Routing Number / Account Number", "examples": ["Routing: 121XXXXXX, Account: XXXXXXXXX"]},
    {"id": "line_item", "type": "class", "label": "Line Item", "examples": ["Software Engineering Services - Engineer A - 21 days"]},
    {"id": "line_item_description", "type": "property", "label": "Line Item Description", "examples": ["Software Engineering Services"]},
    {"id": "line_item_quantity", "type": "property", "label": "Quantity", "examples": ["21 days", "1.00"]},
    {"id": "line_item_unit_price", "type": "property", "label": "Unit Price / Rate", "examples": ["$XX.XX per hour"]},
    {"id": "line_item_amount", "type": "property", "label": "Line Item Amount", "examples": ["$X,XXX.XX"]},
    {"id": "employee_reference", "type": "property", "label": "Employee / Contractor Reference", "examples": ["Engineer A (SOW-A)"]},
    {"id": "working_days", "type": "property", "label": "Working Days", "examples": ["21 days"]},
    {"id": "days_off", "type": "property", "label": "Days Off / Leave Days", "examples": ["0 days", "1 day"]},
    {"id": "hours_per_day", "type": "property", "label": "Hours Per Day", "examples": ["8 hours per day"]},
    {"id": "total_amount", "type": "property", "label": "Total Invoice Amount", "examples": ["$XX,XXX.XX"]},
    {"id": "currency", "type": "property", "label": "Invoice Currency", "examples": ["USD"]},
    {"id": "vat_amount", "type": "property", "label": "Sales Tax Amount", "examples": ["0.00 (sales tax exempt)"]},
    {"id": "vat_exemption_note", "type": "property", "label": "Sales Tax Exemption Note", "examples": ["Sales tax not collected --- out-of-state buyer with no nexus."]},
    {"id": "rsd_equivalent", "type": "property", "label": "Foreign Currency Equivalent", "examples": ["n/a (USD-only invoice)"]},
    {"id": "exchange_rate", "type": "property", "label": "Exchange Rate", "examples": ["n/a (USD-only invoice)"]},
    {"id": "payment_method", "type": "property", "label": "Payment Method", "examples": ["ACH Bank Transfer", "Wire Transfer"]},
    {"id": "payment_deadline", "type": "property", "label": "Payment Deadline / Terms", "examples": ["Net 30", "by Contract"]},
    {"id": "invoice_place", "type": "property", "label": "Place of Issue", "examples": ["San Francisco"]},
    {"id": "service_type", "type": "dimension", "label": "Service Type", "examples": ["Software Engineering Services (staff augmentation)", "Programming services", "Infrastructure Setup"]},
    {"id": "billing_model", "type": "dimension", "label": "Billing Model", "examples": ["hourly rate × hours/day × working days", "fixed monthly retainer", "milestone payment"]},
    {"id": "invoice_direction", "type": "dimension", "label": "Invoice Direction", "examples": ["outbound (seller bills client)", "inbound (contractor bills seller)"]},
    {"id": "document_language", "type": "dimension", "label": "Document Language", "examples": ["English only"]},
    {"id": "rebate", "type": "property", "label": "Rebate / Discount", "examples": ["0.00", "0%"]},
    {"id": "issuer_signature_block", "type": "class", "label": "Signature and Responsibility Block", "examples": ["Responsible person details, signature line, optional stamp/seal"]},
    {"id": "constraint_total_calculation", "type": "constraint", "label": "Total Amount Calculation Rule", "description": "Total must equal sum of all line item amounts; for time-based: hourly_rate × hours_per_day × working_days (e.g., $38.00 × 8 × 19 = $5,776.00 USD)"},
    {"id": "constraint_vat_export", "type": "constraint", "label": "Sales Tax Exemption Rule", "description": "Sales tax not collected; out-of-state buyer with no nexus in the seller's state."},
    {"id": "constraint_rsd_conversion", "type": "constraint", "label": "Foreign Currency Conversion Rule", "description": "Foreign-currency invoices must show USD equivalent at the Federal Reserve H.10 rate on the invoice date; for USD-only invoices, this rule is satisfied trivially."}
  ],
  "edges": [
