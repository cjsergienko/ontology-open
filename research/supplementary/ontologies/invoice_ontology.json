        ]
      },
      {
        "id": "constraint_total_calculation",
        "type": "constraint",
        "label": "Total Amount Calculation Rule",
        "description": "Total must equal sum of all line item amounts; for time-based: hourly_rate × hours_per_day × working_days (e.g., $38.00 × 8 × 19 = $5,776.00 USD)"
      },
      {
        "id": "constraint_vat_export",
        "type": "constraint",
        "label": "Sales Tax Exemption Rule",
        "description": "Sales tax not collected; out-of-state buyer with no nexus in the seller's state."
      },
      {
        "id": "constraint_rsd_conversion",
        "type": "constraint",
        "label": "Foreign Currency Conversion Rule",
        "description": "Foreign-currency invoices must show USD equivalent at the Federal Reserve H.10 rate on the invoice date; for USD-only invoices, this rule is satisfied trivially."
      }
